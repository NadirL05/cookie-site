---
import '../styles/global.css';
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import NavIsland from '../components/NavIsland';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  current?: string;
  forestTop?: boolean;
}

const { title = 'La Maison — Cookies Artisanaux', description = '', current = 'home', forestTop = false } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content="#1C3A2A" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
  </head>
  <body class={forestTop ? 'page-forest-top' : ''}>
    <NavIsland client:load current={current} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
