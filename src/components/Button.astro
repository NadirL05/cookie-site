---
interface Props {
  href: string;
  variant?: 'solid' | 'outline';
  label: string;
  external?: boolean;
}

const { href, variant = 'solid', label, external = false } = Astro.props;

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener' }
  : {};

const baseClasses =
  'inline-block font-sans uppercase text-[11px] tracking-[0.15em] px-6 py-[10px] transition-all duration-200 cursor-pointer';

const variantClasses =
  variant === 'solid'
    ? 'bg-forest text-cream hover:opacity-85'
    : 'border border-forest text-forest hover:bg-forest hover:text-cream';
---

<a
  href={href}
  class={`${baseClasses} ${variantClasses}`}
  {...externalAttrs}
>
  {label}
</a>
