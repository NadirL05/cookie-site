---
interface Props {
  href: string;
  variant?: 'solid' | 'outline' | 'inverted';
  label: string;
  external?: boolean;
}

const { href, variant = 'solid', label, external = false } = Astro.props;

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};

const baseClasses =
  'inline-block font-sans uppercase text-[10px] tracking-[0.2em] px-7 py-3 transition-all duration-300 cursor-pointer';

const variantClasses =
  variant === 'solid'
    ? 'bg-forest text-cream hover:bg-forest-mid'
    : variant === 'inverted'
    ? 'bg-cream text-forest hover:bg-gold'
    : 'border border-forest/60 text-forest hover:border-forest hover:bg-forest hover:text-cream';
---

<a
  href={href}
  class={`${baseClasses} ${variantClasses}`}
  {...externalAttrs}
>
  {label}
</a>
