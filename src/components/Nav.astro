---
const links = [
  { label: 'Notre Histoire', href: '/histoire' },
  { label: 'Nos Créations', href: '/creations' },
  { label: 'Contact', href: '/contact' },
];

const pathname = Astro.url.pathname;
---

<nav id="main-nav" class="sticky top-0 z-50 bg-forest transition-all duration-300" aria-label="Navigation principale">
  <div class="flex items-center justify-between px-8 py-5">
    <!-- Brand logo -->
    <a href="/" class="font-display italic text-cream text-[22px] leading-none tracking-wide">
      La Maison
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(({ label, href }) => (
        <li>
          <a
            href={href}
            aria-current={pathname === href ? 'page' : undefined}
            class={`font-sans uppercase tracking-[0.15em] text-[11px] text-cream/80 hover:text-cream transition-colors pb-0.5 ${pathname === href ? 'border-b border-cream text-cream' : ''}`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-[5px] cursor-pointer p-1"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span class="block w-6 h-px bg-cream"></span>
      <span class="block w-6 h-px bg-cream"></span>
      <span class="block w-6 h-px bg-cream"></span>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div
    id="nav-mobile"
    class="hidden md:hidden bg-forest"
    aria-hidden="true"
  >
    <ul>
      {links.map(({ label, href }) => (
        <li class="border-b border-cream/20">
          <a
            href={href}
            aria-current={pathname === href ? 'page' : undefined}
            class={`block w-full px-8 py-4 font-sans uppercase text-[16px] tracking-[0.15em] hover:bg-cream/10 transition-colors duration-150 ${pathname === href ? 'text-cream font-medium' : 'text-cream/80'}`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) {
      menu?.classList.add('hidden');
      menu?.setAttribute('aria-hidden', 'true');
    } else {
      menu?.classList.remove('hidden');
      menu?.setAttribute('aria-hidden', 'false');
    }
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Subtle border-bottom on scroll
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('border-b', 'border-forest-mid');
    } else {
      nav?.classList.remove('border-b', 'border-forest-mid');
    }
  }, { passive: true });
</script>
