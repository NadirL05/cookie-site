---
const links = [
  { label: 'Notre Histoire', href: '/histoire' },
  { label: 'Nos Créations', href: '/creations' },
  { label: 'Contact', href: '/contact' },
];
---

<nav class="sticky top-0 z-50 bg-forest" aria-label="Navigation principale">
  <div class="flex items-center justify-between px-8 py-4">
    <!-- Brand logo -->
    <a href="/" class="font-display italic text-cream text-[22px] leading-none tracking-wide">
      La Maison
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-sans uppercase text-cream text-[11px] tracking-[0.15em] relative
                   after:absolute after:bottom-[-2px] after:left-0 after:w-0 after:h-px
                   after:bg-cream after:transition-all after:duration-200
                   hover:after:w-full"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-[5px] cursor-pointer p-1"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span class="block w-6 h-px bg-cream"></span>
      <span class="block w-6 h-px bg-cream"></span>
      <span class="block w-6 h-px bg-cream"></span>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div
    id="nav-mobile"
    class="hidden md:hidden bg-forest"
    aria-hidden="true"
  >
    <ul>
      {links.map(({ label, href }) => (
        <li class="border-b border-cream/20">
          <a
            href={href}
            class="block w-full px-8 py-4 font-sans uppercase text-cream text-[16px] tracking-[0.15em]
                   hover:bg-cream/10 transition-colors duration-150"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) {
      menu?.classList.add('hidden');
      menu?.setAttribute('aria-hidden', 'true');
    } else {
      menu?.classList.remove('hidden');
      menu?.setAttribute('aria-hidden', 'false');
    }
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
