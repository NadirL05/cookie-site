---
// Scène 3D — plusieurs cookies figés en arrière-plan, Three.js
---

<canvas id="cookie-canvas" aria-hidden="true"></canvas>
<div id="click-hint" aria-hidden="true">Cliquez n'importe où !</div>

<style>
  #cookie-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  #click-hint {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(28, 58, 42, 0.4);
    pointer-events: none;
    animation: pulse 3s ease-in-out infinite;
    transition: opacity 0.8s ease;
  }

  #click-hint.hidden {
    opacity: 0;
    animation: none;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.9; }
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('cookie-canvas') as HTMLCanvasElement;
  const hint = document.getElementById('click-hint')!;

  // ── Renderer ────────────────────────────────────────────────
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 0.95;

  // ── Scene & fog ─────────────────────────────────────────────
  const scene = new THREE.Scene();
  scene.background = new THREE.Color('#F2E9D8');
  scene.fog = new THREE.Fog('#F2E9D8', 14, 28);

  // ── Camera — vue légèrement plongeante ──────────────────────
  const camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 60);
  camera.position.set(0, 7, 12);
  camera.lookAt(0, -0.5, 0);

  // ── Lumières 3 points ───────────────────────────────────────

  // 1. Lumière principale — chaud, de dessus-gauche
  const keyLight = new THREE.DirectionalLight('#FFF0D0', 4.0);
  keyLight.position.set(-5, 10, 6);
  keyLight.castShadow = true;
  keyLight.shadow.mapSize.set(2048, 2048);
  keyLight.shadow.camera.left = -14;
  keyLight.shadow.camera.right = 14;
  keyLight.shadow.camera.top = 14;
  keyLight.shadow.camera.bottom = -14;
  keyLight.shadow.bias = -0.001;
  scene.add(keyLight);

  // 2. Fill light — doux, de droite
  const fillLight = new THREE.DirectionalLight('#D4B896', 1.2);
  fillLight.position.set(7, 3, -2);
  scene.add(fillLight);

  // 3. Rim light — froid-bleuté derrière pour séparer du fond
  const rimLight = new THREE.DirectionalLight('#C8D8E8', 0.6);
  rimLight.position.set(0, 4, -10);
  scene.add(rimLight);

  // Ambient chaud
  scene.add(new THREE.AmbientLight('#FFF5E8', 1.0));

  // ── Plan de sol (ombre portée) ───────────────────────────────
  const floor = new THREE.Mesh(
    new THREE.PlaneGeometry(40, 40),
    new THREE.ShadowMaterial({ opacity: 0.18, color: '#6B3A1A' })
  );
  floor.rotation.x = -Math.PI / 2;
  floor.position.y = -0.22;
  floor.receiveShadow = true;
  scene.add(floor);

  // ── Matériaux partagés ──────────────────────────────────────
  const chipMat = new THREE.MeshPhysicalMaterial({
    color: '#1E0C02',
    roughness: 0.55,
    metalness: 0.08,
    clearcoat: 0.3,
    clearcoatRoughness: 0.5,
  });

  // ── Fabrique un cookie ──────────────────────────────────────
  function makeCookie(scale = 1): THREE.Group {
    const group = new THREE.Group();

    // Corps du cookie — cylindre déformé
    const r = 1.8 * scale;
    const geo = new THREE.CylinderGeometry(r, r * 0.94, 0.22 * scale, 72, 4);
    const pos = geo.attributes.position;

    for (let i = 0; i < pos.count; i++) {
      const x = pos.getX(i);
      const y = pos.getY(i);
      const z = pos.getZ(i);
      const rad = Math.sqrt(x * x + z * z);
      const angle = Math.atan2(z, x);

      // Bord ondulé organique
      if (rad > r * 0.85) {
        const bumps =
          Math.sin(angle * 8 + 0.3) * 0.04 * scale +
          Math.sin(angle * 15 + 1.1) * 0.02 * scale +
          Math.cos(angle * 5 - 0.7) * 0.025 * scale;
        const newR = rad + bumps;
        pos.setX(i, (x / rad) * newR);
        pos.setZ(i, (z / rad) * newR);
      }

      // Surface rugueuse sur le dessus/dessous
      if (Math.abs(y) > 0.08 * scale) {
        pos.setY(i, y + (Math.random() * 0.018 - 0.009) * scale);
        // Légère boursouflure au centre
        const d = Math.sqrt(x*x + z*z) / r;
        if (d < 0.5) pos.setY(i, pos.getY(i) + (1 - d * 2) * 0.012 * scale);
      }
    }
    geo.computeVertexNormals();

    // Matériau cookie avec variations de couleur par instance
    const hue = (Math.random() - 0.5) * 0.03;
    const cookieMat = new THREE.MeshPhysicalMaterial({
      color: new THREE.Color().setHSL(0.07 + hue, 0.62, 0.46),
      roughness: 0.82,
      metalness: 0.0,
      clearcoat: 0.06,
      clearcoatRoughness: 0.9,
      sheen: 0.15,
      sheenColor: new THREE.Color('#D4A060'),
    });

    const body = new THREE.Mesh(geo, cookieMat);
    body.castShadow = true;
    body.receiveShadow = true;
    group.add(body);

    // Pépites de chocolat
    const nChips = Math.floor(12 + Math.random() * 10);
    for (let i = 0; i < nChips; i++) {
      const angle = Math.random() * Math.PI * 2;
      const dist = (0.2 + Math.random() * 0.72) * r;
      const cx = Math.cos(angle) * dist;
      const cz = Math.sin(angle) * dist;

      const chipR = (0.055 + Math.random() * 0.055) * scale;
      const chipGeo = new THREE.SphereGeometry(chipR, 8, 6);
      const chip = new THREE.Mesh(chipGeo, chipMat);
      chip.position.set(cx, 0.1 * scale + chipR * 0.4, cz);
      chip.scale.y = 0.52 + Math.random() * 0.25;
      chip.castShadow = true;
      group.add(chip);
    }

    // Craquelures (lignes sombres)
    const crackLineMat = new THREE.LineBasicMaterial({
      color: '#7A4010',
      transparent: true,
      opacity: 0.28,
    });
    const nCracks = 4 + Math.floor(Math.random() * 4);
    for (let c = 0; c < nCracks; c++) {
      const startAngle = Math.random() * Math.PI * 2;
      const pts: THREE.Vector3[] = [];
      let cr = 0.05 * scale;
      let ca = startAngle;
      while (cr < r * 0.9) {
        pts.push(new THREE.Vector3(Math.cos(ca) * cr, 0.12 * scale, Math.sin(ca) * cr));
        cr += (0.08 + Math.random() * 0.12) * scale;
        ca += (Math.random() - 0.5) * 0.5;
      }
      if (pts.length > 1) {
        group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), crackLineMat));
      }
    }

    return group;
  }

  // ── Disposition des cookies dans la scène ───────────────────
  // [x, z, scale, rotY, rotX-tilt]
  const layout = [
    [  1.2,  0.5, 1.05,  0.4,  -0.12 ],  // centre-droite — le plus grand
    [ -4.2, -0.3, 0.78, -0.7,  -0.16 ],  // gauche
    [  5.2, -1.2, 0.62,  1.3,  -0.10 ],  // droite loin
    [ -6.5,  1.8, 0.58,  2.0,  -0.20 ],  // bord gauche
    [ -0.8, -3.2, 0.72, -0.3,  -0.08 ],  // haut centre (loin)
    [  3.8,  2.8, 0.50,  0.9,  -0.22 ],  // avant droite
    [ -2.5,  3.2, 0.44, -1.6,  -0.18 ],  // avant gauche
    [  7.0,  0.8, 0.40,  1.8,  -0.14 ],  // bord droit loin
  ];

  const cookieGroups: THREE.Group[] = [];

  layout.forEach(([x, z, scale, rotY, tilt]) => {
    const g = makeCookie(scale);
    g.position.set(x, 0, z);
    g.rotation.y = rotY;
    g.rotation.x = tilt; // légère inclinaison pour voir le relief
    cookieGroups.push(g);
    scene.add(g);
  });

  // ── Physique pépites volantes ───────────────────────────────
  interface Chip {
    mesh: THREE.Mesh;
    vel: THREE.Vector3;
    spin: THREE.Euler;
    life: number;
    maxLife: number;
  }

  const flying: Chip[] = [];
  const flyMat = new THREE.MeshPhysicalMaterial({
    color: '#1E0C02',
    roughness: 0.5,
    metalness: 0.1,
  });
  const GRAVITY = -16;

  function explode() {
    // Explosion depuis chaque cookie
    cookieGroups.forEach(g => {
      const count = 8 + Math.floor(Math.random() * 6);
      for (let i = 0; i < count; i++) {
        const geo = new THREE.SphereGeometry(0.06 + Math.random() * 0.09, 7, 5);
        const mesh = new THREE.Mesh(geo, flyMat.clone());
        mesh.castShadow = true;

        // Position : surface du cookie en world space
        const angle = Math.random() * Math.PI * 2;
        const dist = Math.random() * 1.6 * (g.scale.x || 1);
        const local = new THREE.Vector3(Math.cos(angle) * dist, 0.15, Math.sin(angle) * dist);
        mesh.position.copy(local).applyMatrix4(g.matrixWorld);

        const speed = 2.5 + Math.random() * 5.5;
        const up = 3 + Math.random() * 4;
        const outAngle = Math.random() * Math.PI * 2;
        const vel = new THREE.Vector3(Math.cos(outAngle) * speed, up, Math.sin(outAngle) * speed);

        const spin = new THREE.Euler(
          (Math.random() - 0.5) * 10,
          (Math.random() - 0.5) * 10,
          (Math.random() - 0.5) * 10
        );

        const maxLife = 1.5 + Math.random() * 1.2;
        scene.add(mesh);
        flying.push({ mesh, vel, spin, life: 0, maxLife });
      }
    });
  }

  function updateFlying(dt: number) {
    for (let i = flying.length - 1; i >= 0; i--) {
      const c = flying[i];
      c.life += dt;

      c.vel.y += GRAVITY * dt;
      c.mesh.position.x += c.vel.x * dt;
      c.mesh.position.y += c.vel.y * dt;
      c.mesh.position.z += c.vel.z * dt;

      c.mesh.rotation.x += c.spin.x * dt;
      c.mesh.rotation.y += c.spin.y * dt;
      c.mesh.rotation.z += c.spin.z * dt;

      c.vel.x *= 1 - dt * 1.5;
      c.vel.z *= 1 - dt * 1.5;

      if (c.mesh.position.y < -0.18) {
        c.mesh.position.y = -0.18;
        c.vel.y *= -0.3;
        c.vel.x *= 0.65;
        c.vel.z *= 0.65;
      }

      const mat = c.mesh.material as THREE.MeshPhysicalMaterial;
      mat.transparent = true;
      mat.opacity = Math.max(0, 1 - Math.pow(c.life / c.maxLife, 1.6));

      if (c.life >= c.maxLife) {
        scene.remove(c.mesh);
        c.mesh.geometry.dispose();
        flying.splice(i, 1);
      }
    }
  }

  // ── Shake ───────────────────────────────────────────────────
  let shakeT = 0;
  let shaking = false;

  // ── Click ───────────────────────────────────────────────────
  let clicked = false;
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.closest('a, button, input, textarea, select')) return;
    explode();
    shakeT = 0; shaking = true;
    if (!clicked) { clicked = true; hint.classList.add('hidden'); }
  });

  // ── Render loop ─────────────────────────────────────────────
  const clock = new THREE.Clock();

  (function animate() {
    requestAnimationFrame(animate);
    const dt = Math.min(clock.getDelta(), 0.05);
    const t = clock.elapsedTime;

    // Les cookies sont figés — juste un micro-respiration (optionnel)
    cookieGroups.forEach((g, i) => {
      g.position.y = Math.sin(t * 0.22 + i * 1.3) * 0.018;
    });

    if (shaking) {
      shakeT += dt;
      const str = Math.max(0, 1 - shakeT / 0.45);
      cookieGroups.forEach((g, i) => {
        g.position.y += Math.sin(shakeT * 55 + i) * 0.07 * str;
      });
      if (shakeT >= 0.45) shaking = false;
    }

    updateFlying(dt);
    renderer.render(scene, camera);
  })();

  // ── Resize ──────────────────────────────────────────────────
  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  }, { passive: true });
</script>
