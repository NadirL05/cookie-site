---
// 3D cookie — Three.js, fixed full screen, clic = explosion de pépites
---

<canvas id="cookie-canvas" aria-hidden="true"></canvas>
<div id="click-hint" aria-hidden="true">Cliquez le cookie !</div>

<style>
  #cookie-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  #click-hint {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(28, 58, 42, 0.45);
    pointer-events: none;
    transition: opacity 1s ease;
    animation: hint-pulse 3s ease-in-out infinite;
  }

  @keyframes hint-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .hint-hidden {
    opacity: 0 !important;
    animation: none !important;
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('cookie-canvas') as HTMLCanvasElement;
  const hint = document.getElementById('click-hint') as HTMLDivElement;

  // ── Renderer ────────────────────────────────────────────────
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.1;

  // ── Scene ───────────────────────────────────────────────────
  const scene = new THREE.Scene();
  scene.background = new THREE.Color('#F2E9D8');

  // ── Camera ──────────────────────────────────────────────────
  const camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 0.1, 100);
  camera.position.set(0, 3.5, 8);
  camera.lookAt(0, 0, 0);

  // ── Lights ──────────────────────────────────────────────────
  scene.add(new THREE.AmbientLight('#fff8f0', 1.4));

  const sun = new THREE.DirectionalLight('#fff3e0', 3.5);
  sun.position.set(4, 8, 5);
  sun.castShadow = true;
  sun.shadow.mapSize.set(2048, 2048);
  sun.shadow.camera.left = -10;
  sun.shadow.camera.right = 10;
  sun.shadow.camera.top = 10;
  sun.shadow.camera.bottom = -10;
  scene.add(sun);

  const fill = new THREE.DirectionalLight('#d4a96a', 0.8);
  fill.position.set(-3, 2, -2);
  scene.add(fill);

  // ── Cookie body ─────────────────────────────────────────────
  const cookieGeo = new THREE.CylinderGeometry(3.6, 3.4, 0.38, 64, 3);
  const pos = cookieGeo.attributes.position;
  for (let i = 0; i < pos.count; i++) {
    const x = pos.getX(i), y = pos.getY(i), z = pos.getZ(i);
    const r = Math.sqrt(x * x + z * z);
    if (r > 3.0) {
      const angle = Math.atan2(z, x);
      const wave = Math.sin(angle * 7) * 0.06 + Math.sin(angle * 13) * 0.03;
      pos.setXYZ(i, x * (1 + wave * 0.04), y + Math.random() * 0.02 - 0.01, z * (1 + wave * 0.04));
    }
    if (Math.abs(y) > 0.15) pos.setY(i, y + Math.random() * 0.025 - 0.012);
  }
  cookieGeo.computeVertexNormals();

  const cookieMat = new THREE.MeshStandardMaterial({ color: '#C8812A', roughness: 0.88, metalness: 0.0 });
  const cookie = new THREE.Mesh(cookieGeo, cookieMat);
  cookie.receiveShadow = true;
  cookie.castShadow = true;
  cookie.rotation.x = -0.18;
  scene.add(cookie);

  // ── Pépites permanentes ─────────────────────────────────────
  const staticChipMat = new THREE.MeshStandardMaterial({ color: '#2A1205', roughness: 0.6, metalness: 0.1 });

  const chipPositions = [
    [0.6, 0.9], [-1.1, 0.5], [1.4, -0.3], [-0.3, -1.2], [0.1, 0.2],
    [1.9, 0.7], [-1.8, -0.6], [0.8, -1.8], [-0.9, 1.5], [2.1, -1.2],
    [-2.2, 1.0], [1.2, 1.8], [-1.5, -1.9], [0.4, -0.5], [-0.6, 0.7],
    [2.5, 0.3], [-2.6, -0.2], [1.7, -0.9], [-1.0, -0.9], [0.0, 1.8],
    [2.0, 1.5], [-2.0, 1.6], [1.5, -2.2], [-1.6, 1.9], [0.3, -2.5],
    [2.8, -0.9], [-2.7, 0.8], [0.9, 2.4], [-0.4, -2.8],
  ];
  chipPositions.forEach(([cx, cz]) => {
    if (Math.sqrt(cx*cx + cz*cz) > 3.2) return;
    const geo = new THREE.SphereGeometry(0.13 + Math.random() * 0.07, 8, 6);
    const chip = new THREE.Mesh(geo, staticChipMat);
    chip.position.set(cx + (Math.random()-0.5)*0.12, 0.22, cz + (Math.random()-0.5)*0.12);
    chip.scale.y = 0.55 + Math.random() * 0.2;
    chip.castShadow = true;
    cookie.add(chip);
  });

  // ── Craquelures ─────────────────────────────────────────────
  const crackMat = new THREE.LineBasicMaterial({ color: '#9B5E1A', transparent: true, opacity: 0.35 });
  [0.3, 1.1, 2.2, 3.5, 4.8, 5.6].forEach(a => {
    const pts: THREE.Vector3[] = [];
    for (let t = 0; t < 1; t += 0.04) {
      const rad = t * (1.8 + Math.random() * 1.2);
      const angle = a + (Math.random() - 0.5) * 0.3 * t;
      pts.push(new THREE.Vector3(Math.cos(angle) * rad, 0.2, Math.sin(angle) * rad));
    }
    cookie.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), crackMat));
  });

  // ── Ombre portée ────────────────────────────────────────────
  const shadowPlane = new THREE.Mesh(
    new THREE.PlaneGeometry(20, 20),
    new THREE.ShadowMaterial({ opacity: 0.15 })
  );
  shadowPlane.rotation.x = -Math.PI / 2;
  shadowPlane.position.y = -0.22;
  shadowPlane.receiveShadow = true;
  scene.add(shadowPlane);

  // ── Physique des pépites volantes ───────────────────────────
  interface FlyingChip {
    mesh: THREE.Mesh;
    vel: THREE.Vector3;
    angVel: THREE.Euler;
    life: number;
    maxLife: number;
  }

  const flyingChips: FlyingChip[] = [];
  const flyMat = new THREE.MeshStandardMaterial({ color: '#2A1205', roughness: 0.55, metalness: 0.1 });
  const GRAVITY = -14;

  function spawnExplosion() {
    const count = 55;
    for (let i = 0; i < count; i++) {
      const geo = new THREE.SphereGeometry(0.1 + Math.random() * 0.12, 7, 5);
      const mesh = new THREE.Mesh(geo, flyMat.clone());
      mesh.castShadow = true;

      // Position de départ : surface du cookie (rayon aléatoire)
      const angle = Math.random() * Math.PI * 2;
      const rad = Math.random() * 3.2;
      mesh.position.set(
        Math.cos(angle) * rad,
        0.2 + Math.random() * 0.1,
        Math.sin(angle) * rad
      );
      // Convertir en world space
      mesh.position.applyMatrix4(cookie.matrixWorld);

      // Vélocité : explosion vers l'extérieur + vers le haut
      const speed = 3.5 + Math.random() * 6;
      const upBias = 4 + Math.random() * 4;
      const spreadAngle = Math.random() * Math.PI * 2;
      const spreadR = 0.4 + Math.random() * 0.8;
      const vel = new THREE.Vector3(
        Math.cos(spreadAngle) * spreadR * speed,
        upBias + Math.random() * 3,
        Math.sin(spreadAngle) * spreadR * speed
      );

      // Rotation angulaire aléatoire
      const angVel = new THREE.Euler(
        (Math.random() - 0.5) * 8,
        (Math.random() - 0.5) * 8,
        (Math.random() - 0.5) * 8
      );

      const maxLife = 1.8 + Math.random() * 1.2;
      scene.add(mesh);
      flyingChips.push({ mesh, vel, angVel, life: 0, maxLife });
    }
  }

  function updateChips(dt: number) {
    for (let i = flyingChips.length - 1; i >= 0; i--) {
      const c = flyingChips[i];
      c.life += dt;
      const t = c.life / c.maxLife;

      // Gravité
      c.vel.y += GRAVITY * dt;

      // Déplacement
      c.mesh.position.x += c.vel.x * dt;
      c.mesh.position.y += c.vel.y * dt;
      c.mesh.position.z += c.vel.z * dt;

      // Rotation
      c.mesh.rotation.x += c.angVel.x * dt;
      c.mesh.rotation.y += c.angVel.y * dt;
      c.mesh.rotation.z += c.angVel.z * dt;

      // Ralentissement de l'air
      c.vel.x *= 1 - dt * 1.2;
      c.vel.z *= 1 - dt * 1.2;

      // Rebond léger sur le sol
      if (c.mesh.position.y < -0.2) {
        c.mesh.position.y = -0.2;
        c.vel.y *= -0.35;
        c.vel.x *= 0.7;
        c.vel.z *= 0.7;
      }

      // Fade out
      const mat = c.mesh.material as THREE.MeshStandardMaterial;
      mat.transparent = true;
      mat.opacity = Math.max(0, 1 - Math.pow(t, 1.5));

      // Suppression
      if (c.life >= c.maxLife) {
        scene.remove(c.mesh);
        c.mesh.geometry.dispose();
        flyingChips.splice(i, 1);
      }
    }
  }

  // ── Shake du cookie ─────────────────────────────────────────
  let shakeTime = 0;
  let isShaking = false;

  function triggerShake() {
    shakeTime = 0;
    isShaking = true;
  }

  // ── Click handler (sur document — canvas reste pointer-events: none) ──
  let hasClicked = false;
  document.addEventListener('click', (e) => {
    // Ignorer les clics sur les liens/boutons
    const target = e.target as HTMLElement;
    if (target.tagName === 'A' || target.tagName === 'BUTTON' || target.closest('a, button, input, textarea')) return;

    spawnExplosion();
    triggerShake();

    if (!hasClicked) {
      hasClicked = true;
      hint.classList.add('hint-hidden');
    }
  });

  // ── Animation loop ───────────────────────────────────────────
  const clock = new THREE.Clock();

  function animate() {
    requestAnimationFrame(animate);
    const dt = Math.min(clock.getDelta(), 0.05); // cap dt
    const t = clock.elapsedTime;

    // Respiration douce
    let baseY = Math.sin(t * 0.3) * 0.04;
    let baseRotY = Math.sin(t * 0.18) * 0.06;

    // Shake sur clic
    if (isShaking) {
      shakeTime += dt;
      const intensity = Math.max(0, 1 - shakeTime / 0.5);
      baseY += Math.sin(shakeTime * 60) * 0.12 * intensity;
      baseRotY += Math.sin(shakeTime * 80) * 0.08 * intensity;
      if (shakeTime >= 0.5) isShaking = false;
    }

    cookie.position.y = baseY;
    cookie.rotation.y = baseRotY;

    updateChips(dt);
    renderer.render(scene, camera);
  }
  animate();

  // ── Resize ──────────────────────────────────────────────────
  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  }, { passive: true });
</script>
