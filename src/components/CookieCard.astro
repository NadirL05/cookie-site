---
interface Props {
  image: string;
  name: string;
  description?: string;
  price: string;
  imageAlt?: string;
}

const { image, name, description, price, imageAlt = name } = Astro.props;
---

<div class="group transition-shadow duration-200 hover:shadow-md">
  <div class="aspect-square w-full overflow-hidden rounded-[4px]">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>

  <p class="font-sans text-[13px] font-medium text-forest mt-[10px]">
    {name}
  </p>

  {description && (
    <p class="font-sans text-[11px] text-[#666] mt-1 line-clamp-2">
      {description}
    </p>
  )}

  <p class="font-sans text-[12px] text-[#888] mt-1">
    {price}
  </p>
</div>
