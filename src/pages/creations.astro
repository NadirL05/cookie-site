---

<Layout
  title="Nos Créations — La Maison"
  description="Six cookies d'auteur. Une carte courte, volontairement."
  current="creations"
  forestTop={true}
>

  <!-- Banner -->
  <section class="page-banner">
    <div class="container page-banner-inner">
      <div>
        <div class="breadcrumbs">
          <a href="/">Maison</a>
          <span class="ornament" style="font-size:0.9rem">✦</span>
          <span style="color:#C8A97E">Nos Créations</span>
        </div>
        <h1>
          Six cookies,<br/>chacun une rencontre.
        </h1>
      </div>
      <p>
        Une carte courte, volontairement. Quatre signatures permanentes, deux saisonnières.
        Toutes cuites le matin même.
      </p>
    </div>
  </section>

  <!-- Grid -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-head">
        <div class="section-head-left reveal">
          <span class="eyebrow"><span style="color:#C8A97E">La carte</span> &nbsp;·&nbsp; 2026</span>
          <hr class="hairline" />
          <h2>
            Une recette, une matière<br/>rare, rien d'autre.
          </h2>
        </div>
        <p class="body-text reveal reveal-delay-1">
          Chaque création part d'un ingrédient singulier — un grand cru, une pistache de Bronte,
          une eau de rose de Damas — autour duquel se construit la recette.
          Les prix s'entendent par cookie ; boîte de six sur demande.
        </p>
      </div>

      <div class="cookie-grid">
        {cookies.map((cookie, i) => (
          <CookieCardDesign client:visible cookie={cookie} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- Pull quote -->
  <section class="pull-quote bg-cream">
    <div class="container reveal">
      <span class="ornament" style="font-size:2rem;display:block;margin-bottom:32px">✦</span>
      <blockquote>
        « Un cookie, c'est une promesse : il doit craquer dehors,<br/>
        garder l'âme au milieu, et laisser un souvenir. »
      </blockquote>
      <cite>Camille B., Chef &amp; Fondatrice</cite>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band bg-forest">
    <div class="container reveal">
      <span class="eyebrow" style="color:#C8A97E">Commander</span>
      <h2>
        Une fournée par jour.<br/>Écrivez-nous la veille.
      </h2>
      <p class="body-text">
        Commande minimum : 3 cookies. Réservation 72h à l'avance, retrait à l'atelier.
      </p>
      <a href="/contact" class="btn btn-primary">
        Passer commande <span class="arrow">→</span>
      </a>
    </div>
  </section>

</Layout>

<script>
  // Reveal on scroll for static elements (non-React)
  const els = document.querySelectorAll('.reveal:not([data-react])');
  if ('IntersectionObserver' in window) {
    const obs = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-in'); obs.unobserve(e.target); } }),
      { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
    );
    els.forEach(el => obs.observe(el));
  } else {
    els.forEach(el => el.classList.add('is-in'));
  }
</script>
