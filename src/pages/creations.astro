    subtitle: 'Framboises confites, chocolat noir, poivre de Timut',
    price: '7€',
    badge: 'Best‑seller',
    image: 'https://images.unsplash.com/photo-1568051243851-f9b136146e97?w=900&q=80&auto=format&fit=crop',
    placeholder: 'p-framboise',
    placeholderLabel: 'COOKIE · FRAMBOISE NOIRE',
  },
  {
    id: 'caramel-miso',
    name: 'Caramel Miso',
    subtitle: 'Caramel à la fleur de sel, miso blanc de Kyoto',
    price: '6€',
    badge: null,
    image: 'https://images.unsplash.com/photo-1499636136210-6f4ee915583e?w=900&q=80&auto=format&fit=crop',
