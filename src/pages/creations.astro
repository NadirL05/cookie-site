    subtitle: 'Thé matcha d\'Uji, zestes de yuzu confits',
    price: '7€',
    badge: 'Nouveauté',
    image: 'https://images.unsplash.com/photo-1587080413959-06b859fb107d?w=900&q=80&auto=format&fit=crop',
    placeholder: 'p-matcha',
    placeholderLabel: 'COOKIE · MATCHA YUZU',
  },
  {
    id: 'pistache-rose',
    name: 'Pistache & Rose',
    subtitle: 'Pistaches de Bronte, eau de rose de Damas',
