  {
    id: 'sarah-b',
    name: 'Sarah‑B',
    subtitle: 'Chocolat noir 70%, fleur de sel de Guérande',
    price: '6€',
    badge: 'Signature',
    image: 'https://images.unsplash.com/photo-1558961363-fa8fdf82db35?w=900&q=80&auto=format&fit=crop',
    placeholder: 'p-chocolate',
    placeholderLabel: 'COOKIE · CHOCOLAT NOIR',
  },
  {
    id: 'matcha-yuzu',
