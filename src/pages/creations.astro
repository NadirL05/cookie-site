    badge: null,
    image: 'https://images.unsplash.com/photo-1606312619070-d48b4c652a52?w=900&q=80&auto=format&fit=crop',
    placeholder: 'p-pistache',
    placeholderLabel: 'COOKIE · PISTACHE ROSE',
  },
  {
    id: 'framboise-noire',
