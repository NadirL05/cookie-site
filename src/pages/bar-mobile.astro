---
import Layout from '../layouts/Layout.astro';

const moments = [
  {
    title: 'Mariages',
    description: 'Une animation raffinée pour votre vin d\'honneur, votre cocktail ou votre soirée dansante.',
    image: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=900&q=80&auto=format&fit=crop',
  },
  {
    title: 'Corporate',
    description: 'Fédérez vos équipes autour d\'un bar mobile élégant lors de vos séminaires, lancements ou soirées d\'entreprise.',
    image: 'https://images.unsplash.com/photo-1551632436-cbf8dd35adfa?w=900&q=80&auto=format&fit=crop',
  },
  {
    title: 'Soirées privées',
    description: 'Anniversaires, garden parties ou réceptions intimes : une expérience cocktail directement chez vous.',
    image: 'https://images.unsplash.com/photo-1575444758702-4a6b9222336e?w=900&q=80&auto=format&fit=crop',
  },
];

const barTypes = [
  {
    num: '01',
    title: 'Bar à cocktails signature',
    description: 'Des créations personnalisées selon votre thème, votre saison et vos envies.',
  },
  {
    num: '02',
    title: 'Bar à mocktails & boissons fraîches',
    description: 'Une alternative sans alcool, élégante et gourmande, pensée pour tous vos invités.',
  },
  {
    num: '03',
    title: 'Bar personnalisé',
    description: 'Un espace bar adapté à votre événement, à votre lieu et à votre identité visuelle.',
  },
];
---

<Layout
  title="Bar mobile événementiel — La Maison"
  description="La Maison propose un bar mobile sur mesure avec cocktails, mocktails et animations pour mariages, événements corporate et soirées privées."
  current="bar-mobile"
  forestTop={true}
>

  <!-- Page banner -->
  <section class="page-banner">
    <div class="container page-banner-inner">
      <div>
        <div class="breadcrumbs">
          <a href="/">Maison</a>
          <span class="ornament" style="font-size:0.9rem">✦</span>
          <span style="color:#C8A97E">Bar Mobile</span>
        </div>
        <h1>Un bar en action<br/>pour chaque<br/>moment unique.</h1>
      </div>
      <div>
        <p>
          Cocktails, mocktails et animations personnalisées : notre bar mobile s'installe sur votre
          lieu d'événement pour créer une expérience conviviale, élégante et sur mesure.
        </p>
        <div style="margin-top:40px">
          <a href="/contact" class="btn btn-ghost">
            Personnaliser mon événement <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bar en action — grande image -->
  <section class="section bg-cream">
    <div class="container">
      <div class="bar-action-grid">
        <div class="bar-action-text reveal">
          <span class="eyebrow"><span style="color:#C8A97E">N° 01</span> &nbsp;·&nbsp; Le Bar</span>
          <hr class="hairline" style="margin:20px 0" />
          <h2>Bar en action.</h2>
          <p class="body-text" style="margin-top:24px">
            Notre équipe imagine et anime un espace bar adapté à votre ambiance, à votre lieu
            et au rythme de votre événement.
          </p>
          <p class="body-text" style="margin-top:16px">
            Du briefing à la dernière tournée, chaque détail est pensé pour que vos invités
            gardent un souvenir inoubliable.
          </p>
        </div>
        <div class="bar-action-img reveal reveal-delay-1">
          <div
            class="bar-main-photo"
            style="background-image:url('https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=1400&q=85&auto=format&fit=crop')"
            role="img"
            aria-label="Bar mobile en action"
          ></div>
          <span class="bar-photo-caption">Service · Événementiel · Sur mesure</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Pour chaque moment unique -->
  <section class="section bg-forest">
    <div class="container">
      <div class="section-head">
        <div class="section-head-left reveal">
          <span class="eyebrow"><span style="color:#C8A97E">N° 02</span> &nbsp;·&nbsp; Événements</span>
          <hr class="hairline" />
          <h2>Pour chaque<br/>moment unique.</h2>
        </div>
        <p class="body-text reveal reveal-delay-1">
          Mariage, séminaire, soirée privée — nous adaptons l'animation et l'ambiance
          du bar à votre événement.
        </p>
      </div>

      <div class="moments-grid">
        {moments.map((m, i) => (
          <article class={`moment-card reveal reveal-delay-${i}`}>
            <div class="moment-img-wrap">
              <div
                class="moment-img"
                style={`background-image:url('${m.image}')`}
                role="img"
                aria-label={m.title}
              ></div>
              <div class="moment-overlay"></div>
              <h3 class="moment-title">{m.title}</h3>
            </div>
            <div class="moment-body">
              <p class="body-text">{m.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Nos bars sur mesure -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-head">
        <div class="section-head-left reveal">
          <span class="eyebrow"><span style="color:#C8A97E">N° 03</span> &nbsp;·&nbsp; Offres</span>
          <hr class="hairline" />
          <h2>Nos bars<br/>sur mesure.</h2>
        </div>
        <p class="body-text reveal reveal-delay-1">
          Trois formules pensées pour s'adapter à tous les événements, toutes les ambiances
          et tous les publics.
        </p>
      </div>

      <div class="values">
        {barTypes.map(b => (
          <div class="value-cell">
            <span class="value-num">{b.num}</span>
            <h3>{b.title}</h3>
            <p class="body-text">{b.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="cta-band bg-forest">
    <div class="container reveal">
      <span class="eyebrow" style="color:#C8A97E">Votre événement</span>
      <h2>
        Prêt à personnaliser<br/>votre événement ?
      </h2>
      <p class="body-text">
        Notre équipe étudie chaque projet pour proposer une animation bar sur mesure,
        adaptée à vos envies, à votre lieu et à vos invités.
      </p>
      <a href="/contact" class="btn btn-primary">
        Contactez-nous <span class="arrow">→</span>
      </a>
    </div>
  </section>

</Layout>

<style>
  /* Bar action layout */
  .bar-action-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .bar-action-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
  .bar-action-text h2 {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.2rem, 4.4vw, 4rem);
    margin: 20px 0 0;
  }
  .bar-action-img {
    aspect-ratio: 4 / 5;
    position: relative;
    overflow: hidden;
    border-radius: 0.2rem;
  }
  .bar-main-photo {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    filter: saturate(0.9) contrast(1.02);
  }
  .bar-action-img:hover .bar-main-photo { transform: scale(1.03); }
  .bar-action-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(20,41,30,0.6) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .bar-photo-caption {
    position: absolute;
    left: 20px;
    bottom: 20px;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,239,224,0.55);
    z-index: 2;
  }

  /* Moments grid */
  .moments-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  @media (max-width: 900px) {
    .moments-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .moments-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .moment-card {
    display: flex;
    flex-direction: column;
    background: rgba(245,239,224,0.04);
  }
  .moment-img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }
  .moment-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    filter: saturate(0.75) brightness(0.75);
  }
  .moment-card:hover .moment-img {
    transform: scale(1.04);
    filter: saturate(0.85) brightness(0.82);
  }
  .moment-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(14,28,20,0.85) 100%);
    z-index: 1;
  }
  .moment-title {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    z-index: 2;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.8rem;
    color: #F5EFE0;
    margin: 0;
  }
  .moment-body {
    padding: 24px;
    background: rgba(245,239,224,0.05);
    border-top: 1px solid rgba(245,239,224,0.1);
  }
  .moment-body .body-text {
    color: rgba(245,239,224,0.7);
    font-size: 0.9rem;
  }
</style>

<script>
  const els = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const obs = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-in'); obs.unobserve(e.target); } }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    els.forEach(el => obs.observe(el));
  } else {
    els.forEach(el => el.classList.add('is-in'));
  }
</script>
