---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm';
---

<Layout title="Contact — La Maison" description="Contactez-nous pour passer commande ou en savoir plus sur nos cookies artisanaux.">

  <!-- Section 1 — Header -->
  <section class="bg-forest text-center py-20 px-8">
    <p class="font-sans uppercase text-gold/80 text-[10px] tracking-[0.3em]">Restons en Contact</p>
    <h1 class="font-display italic text-5xl text-cream mt-3">Contact</h1>
    <p class="font-sans text-sm text-cream/60 mt-4">Pour commander, poser une question ou proposer un événement.</p>
  </section>

  <!-- Section 2 — Content (2 columns) -->
  <section class="bg-cream py-16 px-8">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Colonne gauche — Formulaire -->
      <div>
        <h2 class="font-display italic text-2xl text-forest mb-8">Envoyez-nous un message</h2>
        <ContactForm client:load />
      </div>

      <!-- Colonne droite — Infos -->
      <div>
        <h2 class="font-display italic text-2xl text-forest mb-8">Retrouvez-nous</h2>
        <div class="space-y-6">
          <div>
            <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-forest/50 mb-1">Instagram</p>
            <a href="https://instagram.com/lamaisoncookies" target="_blank" rel="noopener noreferrer" class="font-sans text-sm text-brown hover:text-forest transition-colors">@lamaisoncookies</a>
          </div>
          <div>
            <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-forest/50 mb-1">Email</p>
            <a href="mailto:hello@lamaisoncookies.fr" class="font-sans text-sm text-brown hover:text-forest transition-colors">hello@lamaisoncookies.fr</a>
          </div>
          <div>
            <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-forest/50 mb-1">Localisation</p>
            <p class="font-sans text-sm text-brown">Paris, France</p>
          </div>
          <div>
            <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-forest/50 mb-1">Commande</p>
            <p class="font-sans text-sm text-brown">Via Instagram ou email — réponse sous 24h.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Section 3 — Instagram CTA -->
  <section class="bg-forest text-center py-12 px-8">
    <p class="font-display italic text-cream text-2xl">Suivez nos créations sur Instagram</p>
    <a
      href="https://instagram.com"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block mt-6 border border-cream text-cream font-sans uppercase tracking-[0.15em] text-[11px] px-8 py-3 hover:bg-cream hover:text-forest transition-colors"
    >
      @lamaisoncookies →
    </a>
  </section>

</Layout>
