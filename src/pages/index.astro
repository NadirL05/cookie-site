---
import Layout from '../layouts/Layout.astro';
import CookieCardDesign from '../components/CookieCardDesign';

const featured = [
  {
    id: 'sarah-b',
    name: 'Sarah‑B',
    subtitle: 'Chocolat noir 70%, fleur de sel de Guérande',
    price: '6€',
    badge: 'Signature',
    placeholder: 'p-chocolate',
    placeholderLabel: 'COOKIE · CHOCOLAT NOIR',
  },
  {
    id: 'matcha-yuzu',
    name: 'Matcha Yuzu',
    subtitle: 'Thé matcha d\'Uji, zestes de yuzu confits',
    price: '7€',
    badge: 'Nouveauté',
    placeholder: 'p-matcha',
    placeholderLabel: 'COOKIE · MATCHA YUZU',
  },
  {
    id: 'framboise-noire',
    name: 'Framboise Noire',
    subtitle: 'Framboises confites, chocolat noir, poivre de Timut',
    price: '7€',
    badge: 'Best‑seller',
    placeholder: 'p-framboise',
    placeholderLabel: 'COOKIE · FRAMBOISE NOIRE',
  },
];

const values = [
  { num: '01', title: 'La fournée unique', text: 'Une seule cuisson par jour, le matin. Ce qui n\'est pas réservé n\'est pas cuit.' },
  { num: '02', title: 'Matières rares', text: 'Chocolat grand cru, vanille de Madagascar, pistaches de Bronte. Sourcing lent.' },
  { num: '03', title: 'Fait main', text: 'Chaque cookie est façonné à la main. Aucune machine, aucun surgelé.' },
];
---

<Layout
  title="La Maison — Cookies d'auteur · Paris"
  description="Une fournée par jour. Cookies artisanaux façonnés à la main, sur commande, au cœur de Paris."
  current="home"
  forestTop={true}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-img">
      <div class="placeholder-hero"></div>
    </div>
    <span class="hero-meta">N° 01 — Maison</span>
    <span class="hero-meta-right">Paris · 75004<br/>Atelier de Turenne</span>

    <div class="hero-content">
      <div class="hero-eyebrow eyebrow">Paris · Depuis MMXV</div>
      <h1 class="hero-title">
        Une fournée<br/>
        <span style="display:inline-block">par jour<span class="ornament"> ✦ </span>rien de plus.</span>
      </h1>
      <p class="hero-tagline">
        « Quand la gourmandise devient un souvenir. »
      </p>
      <div class="hero-cta">
        <a href="/creations" class="btn btn-primary">
          Voir nos créations <span class="arrow">→</span>
        </a>
        <a href="/histoire" class="btn btn-ghost">
          Notre histoire
        </a>
      </div>
    </div>

    <div class="hero-scroll">Scroll</div>
  </section>

  <!-- Featured cookies -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-head">
        <div class="section-head-left reveal">
          <span class="eyebrow"><span style="color:#C8A97E">N° 02</span> &nbsp;·&nbsp; Sélection</span>
          <hr class="hairline" />
          <h2>
            Trois créations<br/>emblématiques.
          </h2>
        </div>
        <p class="body-text reveal reveal-delay-1">
          Six recettes, façonnées à la main chaque matin, à partir de matières rares.
          Voici les trois qui reviennent le plus souvent dans vos commandes.
        </p>
      </div>

      <div class="cookie-grid">
        {featured.map((cookie, i) => (
          <CookieCardDesign client:visible cookie={cookie} index={i} />
        ))}
      </div>

      <div class="reveal" style="margin-top:80px;text-align:center">
        <a href="/creations" class="btn btn-primary">
          Toutes les créations <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Histoire band -->
  <section class="histoire-band">
    <div class="container">
      <div class="histoire-grid">
        <div class="histoire-image reveal">
          <div class="placeholder-hero"></div>
          <span class="histoire-image-caption">Atelier · Rue de Turenne · 2025</span>
        </div>
        <div class="histoire-text reveal reveal-delay-1">
          <span class="eyebrow"><span style="color:#C8A97E">N° 03</span> &nbsp;·&nbsp; Notre Histoire</span>
          <h2>
            Dix ans à ne rien<br/>presser.
          </h2>
          <p class="body-text" style="margin-bottom:20px">
            Camille a quitté son métier en 2015 pour cuire des cookies. Depuis, rien n'a changé :
            une fournée par jour, à la main, sur commande. Pas d'e-commerce. Pas de croissance à tout prix.
          </p>
          <p class="body-text" style="margin-bottom:36px">
            Juste la patience d'une recette. Et des clients qui reviennent.
          </p>
          <a href="/histoire" class="btn btn-ghost">
            Lire l'histoire <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-head">
        <div class="section-head-left reveal">
          <span class="eyebrow"><span style="color:#C8A97E">N° 04</span> &nbsp;·&nbsp; La maison</span>
          <hr class="hairline" />
          <h2>Trois règles,<br/>jamais enfreintes.</h2>
        </div>
        <p class="body-text reveal reveal-delay-1">
          Le luxe, pour nous, c'est le refus. Refus de la machine, refus de la quantité,
          refus du surgelé.
        </p>
      </div>

      <div class="values reveal">
        {values.map(v => (
          <div class="value-cell">
            <span class="value-num">{v.num}</span>
            <h3>{v.title}</h3>
            <p class="body-text">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band bg-forest">
    <div class="container reveal">
      <span class="eyebrow" style="color:#C8A97E">N° 05 · Commander</span>
      <h2>
        <span class="ornament">✦</span> Écrivez-nous<br/>
        la veille au soir.
      </h2>
      <p class="body-text">
        Les commandes se prennent par Instagram ou e-mail, 72 heures à l'avance.
        Retrait à l'atelier du 4ᵉ, du mardi au samedi.
      </p>
      <a href="/contact" class="btn btn-primary">
        Passer commande <span class="arrow">→</span>
      </a>
    </div>
  </section>

</Layout>

<script>
  const els = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const obs = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-in'); obs.unobserve(e.target); }
      }),
      { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
    );
    els.forEach(el => obs.observe(el));
  } else {
    els.forEach(el => el.classList.add('is-in'));
  }
</script>
